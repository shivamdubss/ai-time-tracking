# Donna Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required (for local dev without Supabase) ─────────────
# Your Anthropic API key for Claude AI session summarization.
# Not needed if using Supabase Edge Function (cloud mode).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Auth ────────────────────────────────────────────────────
# Local API auth token. Auto-generated on first run if left blank.
# TIMETRACK_AUTH_TOKEN=

# ─── Supabase (for cloud auth + sync) ──────────────────────
# Get these from your Supabase project settings > API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# Edge Function URL for cloud summarization (optional)
# SUPABASE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/summarize

# ─── Frontend Supabase config ──────────────────────────────
# Set these in frontend/.env or as VITE_ prefixed vars
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional Overrides ─────────────────────────────────────
# Claude model for summarization (default: claude-sonnet-4-20250514)
# TIMETRACK_MODEL=claude-sonnet-4-20250514

# Screenshot capture interval in seconds (default: 30)
# TIMETRACK_SCREENSHOT_INTERVAL=30

# Window title polling interval in seconds (default: 3)
# TIMETRACK_WINDOW_INTERVAL=3

# Database directory (default: platform-specific, e.g. ~/Library/Application Support/Donna)
# TIMETRACK_DB_DIR=

# Backend port (default: 8000)
# TIMETRACK_PORT=8000

# Sync interval in seconds (default: 300 = 5 min)
# TIMETRACK_SYNC_INTERVAL=300
